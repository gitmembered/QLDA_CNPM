@model IEnumerable<QLThuocBenhVien.Models.PhieuNhap>
@{
    ViewData["Title"] = "Lịch Sử Nhập Kho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Lịch Sử Nhập Kho</h3>
        <p class="text-muted">Xem lại và giám sát toàn bộ danh sách phiếu nhập kho dược phẩm bện viện.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 fw-medium shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-2"></i>Lập Phiếu Mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="custom-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th width="15%">MÃ PHIẾU</th>
                    <th width="20%">NGÀY NHẬP KHO</th>
                    <th width="30%">NHÀ CUNG CẤP</th>
                    <th width="20%" class="text-end">TỔNG GIÁ TRỊ</th>
                    <th width="15%" class="text-center">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">#PN-@item.MaPN.ToString("D4")</td>
                        <td>@item.NgayNhap.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-medium">@item.NhaCungCap?.TenNCC</td>
                        <td class="text-end fw-bold text-danger">@item.TongTien.ToString("N0") đ</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaPN" class="btn btn-sm btn-outline-secondary px-3"
                               style="border-radius: 6px;">
                                <i class="bi bi-eye me-1"></i> Xem chi tiết
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu phiếu nhập kho nào được lập.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>