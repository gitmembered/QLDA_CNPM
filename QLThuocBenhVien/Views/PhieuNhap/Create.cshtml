@{
    ViewData["Title"] = "Lập Phiếu Nhập";
}

<div class="mb-4">
    <h3 class="fw-bold mb-1">Lập Phiếu Nhập Kho</h3>
    <p class="text-muted">Tạo phiếu nhập mới để thêm lô thuốc vào kho lưu trữ.</p>
</div>

<form asp-action="Create" method="post">

    <div class="custom-card mb-4">
        <h5 class="fw-bold border-bottom pb-2 mb-3 text-dark"><i class="bi bi-info-circle me-2 text-primary"></i>Thông
            tin chung</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark">Nhà Cung Cấp <span class="text-danger">*</span></label>
                    <select name="MaNCC" class="form-select" asp-items="ViewBag.NhaCungCapList" required>
                        <option value="">-- Chọn Nhà Cung Cấp --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-dark">Thời gian nhập kho</label>
                    <input type="datetime-local" name="NgayNhap" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold text-dark">Ghi chú / Diễn giải</label>
                    <textarea name="GhiChu" class="form-control" rows="2"
                              placeholder="Ghi chú thêm về lô hàng (nếu có)..."></textarea>
                </div>
            </div>
        </div>

        <div class="custom-card">
            <h5 class="fw-bold border-bottom pb-2 mb-3 text-dark"><i class="bi bi-box-seam me-2 text-primary"></i>Chi tiết
                hàng nhập</h5>
                <div class="table-responsive" style="overflow: visible;">
                    <table class="table align-middle" id="importTable">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 35%">Dược phẩm trong danh mục</th>
                                <th style="width: 12%">Số lượng</th>
                                <th style="width: 15%">Đơn giá nhập</th>
                                <th style="width: 15%">Đơn giá xuất</th>
                                <th style="width: 18%">Thành tiền nhập</th>
                                <th style="width: 5%" class="text-center">#</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="import-row">
                                <td>
                                    <select name="MaThuoc[]" class="form-select drug-select shadow-none" required>
                                        <option value="">-- Gõ tên thuốc để tìm --</option>
                                        @foreach (var t in ViewBag.ThuocDanhMucList)
                                        {
                                            <option value="@t.MaThuoc" data-giaxuat="@t.GiaBan">@t.TenThuoc (@t.HoatChat)</option>
                                        }
                                    </select>
                                </td>
                                <td><input type="number" name="SoLuong[]" class="form-control qty-input shadow-none" min="1"
                                               value="1" required /></td>
                                    <td><input type="number" name="DonGiaNhap[]" class="form-control price-input shadow-none"
                                                   min="0" required /></td>
                                        <td><input type="number" name="DonGiaXuat[]" class="form-control sale-input shadow-none" min="0"
                                                       required /></td>
                                            <td><input type="text" class="form-control row-total shadow-none bg-light fw-bold text-dark"
                                                           value="0 đ" readonly /></td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-link text-danger p-0 delete-row shadow-none"><i
                                                        class="bi bi-trash fs-5"></i></button>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                                        <button type="button" id="btnAddRow" class="btn btn-outline-primary bg-transparent btn-sm px-3 fw-medium"
                                                style="border-radius: 8px;">
                                            <i class="bi bi-plus me-1"></i> Thêm Dòng Khác
                                        </button>
                                        <div class="fs-5">
                                            <span class="text-muted me-2 fs-6">Tổng cộng:</span>
                                            <span class="fw-bold text-danger fs-4" id="grandTotal">0 đ</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="text-end mt-4">
                                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                                        <i class="bi bi-floppy me-2"></i> Lưu Phiếu Nhập
                                    </button>
                                </div>
                            </form>

                            @section Scripts {
                                <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                                <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
                                <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

                                <script>
                                    $(document).ready(function () {
                                    function initSelect2(element) {
                                    element.select2({
                                    theme: 'bootstrap-5',
                                    width: '100%',
                                    placeholder: '-- Gõ tên thuốc để tìm --'
                                    });
                                    }

                                    initSelect2($('.drug-select'));

                                    function calculateTotals() {
                                    let grandTotal = 0;
                                    $('#importTable tbody .import-row').each(function () {
                                    const row = $(this);
                                    const qty = parseFloat(row.find('.qty-input').val()) || 0;
                                    const price = parseFloat(row.find('.price-input').val()) || 0;
                                    const rowTotal = qty * price;

                                    row.find('.row-total').val(rowTotal.toLocaleString('vi-VN') + " đ");
                                    grandTotal += rowTotal;
                                    });
                                    $('#grandTotal').text(grandTotal.toLocaleString('vi-VN') + " đ");
                                    }

                                    $('#importTable').on('change', '.drug-select', function () {
                                    const row = $(this).closest('.import-row');
                                    const selectedOption = $(this).find('option:selected');
                                    const giaXuatDb = selectedOption.data('giaxuat') || 0;
                                    row.find('.sale-input').val(giaXuatDb);
                                    calculateTotals();
                                    });

                                    $('#importTable').on('input', '.qty-input, .price-input', function () {
                                    calculateTotals();
                                    });

                                    // ================= ĐÃ SỬA LẠI LOGIC THÊM DÒNG TỐI ƯU =================
                                    $('#btnAddRow').click(function () {
                                    const tableBody = $('#importTable tbody');

                                    // 1. Phá hủy Select2 của dòng đầu tiên để lấy HTML sạch (không dính ID ngầm)
                                    const firstSelect = tableBody.find('.import-row:first .drug-select');
                                    firstSelect.select2('destroy');

                                    // 2. Clone dòng đầu tiên (lúc này là thẻ <select> thuần túy)
                                    const newRow = tableBody.find('.import-row:first').clone();

                                    // 3. Reset các giá trị để nhập mới
                                    newRow.find('.drug-select').val('');
                                    newRow.find('.qty-input').val(1);
                                    newRow.find('.price-input').val('');
                                    newRow.find('.sale-input').val('');
                                    newRow.find('.row-total').val('0 đ');

                                    // 4. Thêm vào bảng
                                    tableBody.append(newRow);

                                    // 5. Kích hoạt lại Select2 cho TOÀN BỘ các thẻ trong bảng (cả dòng 1 vừa bị hủy lẫn dòng mới)
                                    initSelect2($('.drug-select'));
                                    calculateTotals();
                                    });

                                    $('#importTable').on('click', '.delete-row', function () {
                                    if ($('#importTable tbody .import-row').length > 1) {
                                    $(this).closest('.import-row').remove();
                                    calculateTotals();
                                    } else {
                                    alert('Hóa đơn nhập kho phải có ít nhất một mặt hàng!');
                                    }
                                    });
                                    });
                                </script>
                            }