@{
    Layout = null; // Giao diện đăng nhập/đăng ký không dùng chung thanh menu Sidebar
    ViewData["Title"] = "Đăng Ký Tài Khoản";
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Ký - PharmaDash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
    <style>
            body {
                background-color: #F3F4F6;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .auth-card {
                background: white;
                border-radius: 16px;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
                width: 100%;
                max-width: 450px;
                padding: 40px;
            }

            .btn-primary {
                background-color: #2563EB;
                border: none;
                padding: 12px;
                font-weight: 600;
                border-radius: 8px;
            }

            .btn-primary:hover {
                background-color: #1D4ED8;
            }

            .form-control {
                padding: 12px 15px;
                border-radius: 8px;
            }

            .form-control:focus {
                box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.25);
                border-color: #2563EB;
            }
    </style>
</head>

<body>
    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark"><i class="bi bi-capsule text-primary me-2"></i>PharmaDash</h2>
            <p class="text-muted">Đăng ký tài khoản nhân sự y tế</p>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger p-2 mb-4 text-center" style="font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.ErrorMessage
            </div>
        }

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold text-dark small">Họ và tên thực tế <span
                    class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="hoTen" placeholder="Ví dụ: Nguyễn Văn A" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-dark small">Tên đăng nhập <span
                        class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="tenDangNhap" placeholder="Dùng để đăng nhập hệ thống"
                               required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark small">Mật khẩu <span
                            class="text-danger">*</span></label>
                            <input type="password" class="form-control" name="matKhau" placeholder="Tối thiểu 5 ký tự" minlength="5"
                                   required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Tạo tài khoản</button>

                        <div class="text-center text-muted small">
                            Đã có tài khoản? <a asp-action="Login" class="text-decoration-none fw-bold text-primary">Đăng nhập
                            ngay</a>
                        </div>
                    </form>
                </div>
            </body>

        </html>