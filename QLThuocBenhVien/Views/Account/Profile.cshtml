@model QLThuocBenhVien.Models.TaiKhoan
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<div class="mb-4">
    <h3 class="fw-bold mb-1">Hồ sơ cá nhân</h3>
    <p class="text-muted">Quản lý thông tin bảo mật và tài khoản của bạn.</p>
</div>

@if (TempData["SuccessMsg"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMsg"]</div>
}
@if (TempData["ErrorMsg"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMsg"]</div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="custom-card text-center py-5 h-100">
            @{
                var avatarSrc = string.IsNullOrEmpty(Model.Avatar) ?
            $"https://ui-avatars.com/api/?name={Model.HoTen}&background=0D8ABC&color=fff&size=150" : Model.Avatar;
            }
            <img src="@avatarSrc" class="rounded-circle mx-auto mb-4 border border-5 border-white shadow-sm"
                 style="width: 120px; height: 120px; object-fit: cover;" alt="Avatar" />

            <h4 class="fw-bold mb-1 text-dark">@Model.HoTen</h4>
            <p class="text-primary fw-medium mb-3">@Model.VaiTro</p>
            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i
                class="bi bi-check-circle-fill me-1"></i> Đang hoạt động</span>
            </div>
        </div>

        <div class="col-md-8">
            <div class="custom-card mb-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Cập nhật thông tin chung</h5>
                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="row g-3">
                    <input type="hidden" name="id" value="@Model.MaTaiKhoan" />
                    <div class="col-md-6">
                        <label class="form-label text-muted">Tên đăng nhập</label>
                        <input type="text" class="form-control bg-light" value="@Model.TenDangNhap" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Họ và tên hiển thị</label>
                        <input type="text" class="form-control" name="hoTen" value="@Model.HoTen" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Ảnh đại diện (Avatar)</label>
                        <input type="file" class="form-control" name="avatarFile" accept="image/png, image/jpeg" />
                    </div>
                    <div class="col-12 text-end mt-4">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Lưu thay
                            đổi</button>
                        </div>
                    </form>
                </div>
                <div class="custom-card">
                    <h5 class="fw-bold mb-3 border-bottom pb-2 text-danger">Đổi mật khẩu hệ thống</h5>
                    <form asp-action="ChangePassword" method="post" class="row g-3">
                        <input type="hidden" name="id" value="@Model.MaTaiKhoan" />
                        <div class="col-12">
                            <input type="password" class="form-control mb-2" name="oldPassword" placeholder="Mật khẩu hiện tại"
                                   required />
                            <input type="password" class="form-control" name="newPassword"
                                   placeholder="Mật khẩu mới (Tối thiểu 5 ký tự)" required />
                        </div>
                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-danger px-4"><i class="bi bi-key me-2"></i>Đổi mật
                                khẩu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>