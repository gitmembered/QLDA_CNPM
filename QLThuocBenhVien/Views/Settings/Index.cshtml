@model IEnumerable<QLThuocBenhVien.Models.TaiKhoan>
@{
    ViewData["Title"] = "Cài Đặt Hệ Thống";
}

<div class="mb-4">
    <h3 class="fw-bold mb-1">Cài đặt hệ thống</h3>
    <p class="text-muted">Quản trị giao diện, phân quyền người dùng và giám sát nhật ký hoạt động.</p>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="custom-card p-2">
            <div class="nav flex-column nav-pills" id="system-tabs" role="tablist">
                <button class="nav-link active text-start py-2.5 px-3 mb-1" data-bs-toggle="pill"
                        data-bs-target="#theme-panel" type="button">
                    <i class="bi bi-palette me-2"></i> Giao diện (Theme)
                </button>

                @if (User.IsInRole("Admin"))
                {
                    <button class="nav-link text-start py-2.5 px-3 mb-1" data-bs-toggle="pill" data-bs-target="#users-panel"
                            type="button">
                        <i class="bi bi-people me-2"></i> Quản lý người dùng
                    </button>
                    <button class="nav-link text-start py-2.5 px-3" data-bs-toggle="pill" data-bs-target="#logs-panel"
                            type="button">
                        <i class="bi bi-journal-text me-2"></i> Nhật ký (Logs)
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="tab-content custom-card h-100">

            <div class="tab-pane fade show active" id="theme-panel">
                <h5 class="fw-bold border-bottom pb-3 mb-4">Tùy chỉnh giao diện hiển thị</h5>
                <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                    <div>
                        <div class="fw-bold text-dark fs-5"><i class="bi bi-moon-stars me-2 text-primary"></i> Chế độ
                            tối (Dark Mode)</div>
                            <small class="text-muted">Bảo vệ mắt khi làm việc trong môi trường thiếu sáng.</small>
                        </div>
                        <div class="form-check form-switch fs-3 m-0">
                            <input class="form-check-input shadow-none cursor-pointer" type="checkbox" id="darkModeToggle">
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="users-panel">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                        <h5 class="fw-bold mb-0">Tài khoản nhân sự</h5>
                        <button class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> Thêm tài khoản</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Họ Tên</th>
                                    <th>Tên Đăng Nhập</th>
                                    <th>Vai Trò</th>
                                    <th>Trạng Thái</th>
                                    <th>Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td class="fw-bold">@user.HoTen</td>
                                        <td>@user.TenDangNhap</td>
                                        <td><span class="badge bg-secondary">@user.VaiTro</span></td>
                                        <td>
                                            @(user.TrangThai == true ? Html.Raw("<span class='text-success fw-medium'><i class='bi bi-circle-fill small'></i> Hoạt động</span>") : Html.Raw("<span class='text-danger fw-medium'><i class='bi bi-circle-fill small'></i> Bị khóa</span>"))
                                        </td>
                                        <td><button class="btn btn-sm btn-outline-primary">Sửa quyền</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="logs-panel">
                    <h5 class="fw-bold border-bottom pb-3 mb-4 text-dark">Nhật ký hoạt động hệ thống</h5>
                    <ul class="list-group list-group-flush">
                        @if (ViewBag.Logs != null)
                        {
                            foreach (var log in ViewBag.Logs)
                            {
                                // Xác định màu sắc huy hiệu theo loại Log
                                var badgeColor = log.Loai == "Danger" ? "danger" : (log.Loai == "Warning" ? "warning text-dark" :
                        "info text-dark");

                                <li class="list-group-item px-0 py-3 text-muted bg-transparent"
                                    style="border-color: var(--bs-border-color);">
                                    <span class="badge bg-@badgeColor me-2">@log.Loai</span>
                                    [@log.ThoiGian.ToString("dd/MM/yyyy HH:mm")]
                                    <b class="text-dark">@log.NguoiThucHien</b>: @log.NoiDung
                                </li>
                            }
                        }
                    </ul>
                </div>

            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const toggle = document.getElementById('darkModeToggle');
                const htmlTag = document.documentElement;

                // Đồng bộ trạng thái của nút gạt theo theme thực tế của hệ thống
                if (htmlTag.getAttribute('data-bs-theme') === 'dark') {
                    toggle.checked = true;
                }

                // Xử lý sự kiện khi người dùng gạt công tắc bật/tắt
                toggle.addEventListener('change', function () {
                    if (this.checked) {
                        htmlTag.setAttribute('data-bs-theme', 'dark');
                        localStorage.setItem('theme', 'dark');
                    } else {
                        htmlTag.setAttribute('data-bs-theme', 'light');
                        localStorage.setItem('theme', 'light');
                    }
                });
            });
        </script>
    }