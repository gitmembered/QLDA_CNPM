@model IEnumerable<QLThuocBenhVien.Models.TaiKhoan>
@{
    ViewData["Title"] = "Cài Đặt Hệ Thống";
}

<div class="mb-4">
    <h3 class="fw-bold mb-1">Cài đặt hệ thống</h3>
    <p class="text-muted">Quản trị giao diện, phân quyền người dùng và giám sát nhật ký hoạt động.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="custom-card p-2">
            <div class="nav flex-column nav-pills" id="system-tabs" role="tablist">
                <button class="nav-link active text-start py-2.5 px-3 mb-1" data-bs-toggle="pill"
                        data-bs-target="#theme-panel" type="button" role="tab">
                    <i class="bi bi-palette me-2"></i> Giao diện (Theme)
                </button>

                @if (User.IsInRole("Admin"))
                {
                    <button class="nav-link text-start py-2.5 px-3 mb-1" data-bs-toggle="pill" data-bs-target="#users-panel"
                            type="button" role="tab" id="tab-users-panel">
                        <i class="bi bi-people me-2"></i> Quản lý người dùng
                    </button>
                    <button class="nav-link text-start py-2.5 px-3" data-bs-toggle="pill" data-bs-target="#logs-panel"
                            type="button" role="tab" id="tab-logs-panel">
                        <i class="bi bi-journal-text me-2"></i> Nhật ký (Logs)
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="tab-content custom-card h-100">

            <div class="tab-pane fade show active" id="theme-panel" role="tabpanel">
                <h5 class="fw-bold border-bottom pb-3 mb-4">Tùy chỉnh giao diện hiển thị</h5>
                <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                    <div>
                        <div class="fw-bold text-dark fs-5"><i class="bi bi-moon-stars me-2 text-primary"></i> Chế độ
                            tối (Dark Mode)</div>
                            <small class="text-muted">Bảo vệ mắt khi làm việc trong môi trường thiếu sáng.</small>
                        </div>
                        <div class="form-check form-switch fs-3 m-0">
                            <input class="form-check-input shadow-none cursor-pointer" type="checkbox" id="darkModeToggle">
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="users-panel" role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                        <h5 class="fw-bold mb-0 text-dark">Tài khoản nhân sự</h5>
                        <button class="btn btn-sm btn-primary shadow-sm" data-bs-toggle="modal"
                                data-bs-target="#addUserModal">
                            <i class="bi bi-plus-lg"></i> Thêm tài khoản
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Họ Tên</th>
                                    <th>Tên Đăng Nhập</th>
                                    <th>Vai Trò</th>
                                    <th>Trạng Thái</th>
                                    <th>Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var user in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold text-dark">@user.HoTen</td>
                                            <td>@user.TenDangNhap</td>
                                            <td><span class="badge bg-secondary">@user.VaiTro</span></td>
                                            <td>
                                                @if (user.TrangThai == 1)
                                                {
                                                    <span class="text-success fw-medium"><i class="bi bi-circle-fill small"></i> Hoạt
                                                        động</span>
                                                    }
                                            else if (user.TrangThai == 0)
                                                    {
                                                        <span class="text-warning text-dark fw-medium"><i
                                                            class="bi bi-circle-fill small"></i> Chờ duyệt</span>
                                                        }
                                            else
                                                        {
                                                            <span class="text-danger fw-medium"><i class="bi bi-circle-fill small"></i> Bị
                                                                khóa</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary shadow-none" data-bs-toggle="modal"
                                                                    data-bs-target="#editUserModal-@user.MaTaiKhoan">Sửa quyền</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                @if (Model != null && Model.Any())
                                {
                                    foreach (var user in Model)
                                    {
                                        <div class="modal fade" id="editUserModal-@user.MaTaiKhoan" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content custom-card p-0">
                                                    <div class="modal-header border-bottom">
                                                        <h5 class="modal-title fw-bold text-dark">Phân quyền: @user.TenDangNhap</h5>
                                                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <form asp-action="EditUserRole" method="post">
                                                        <div class="modal-body">
                                                            <input type="hidden" name="maTaiKhoan" value="@user.MaTaiKhoan" />

                                                            <div class="mb-3">
                                                                <label class="form-label text-dark fw-medium">Họ và tên</label>
                                                                <input type="text" class="form-control bg-light" value="@user.HoTen" readonly />
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label text-dark fw-medium">Vai trò hệ thống</label>
                                                                <select class="form-select shadow-none" name="vaiTro">
                                                                    @if (user.VaiTro == "BacSi")
                                                                    {
                                                                        <option value="BacSi" selected>Bác Sĩ
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="BacSi">Bác Sĩ</option>
                                                                    }
                                                                    @if (user.VaiTro == "DuocSi")
                                                                    {
                                                                        <option value="DuocSi" selected>Dược Sĩ
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="DuocSi">Dược Sĩ</option>
                                                                    }
                                                                    @if (user.VaiTro == "QuanLy")
                                                                    {
                                                                        <option value="QuanLy" selected>Quản Lý
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="QuanLy">Quản Lý</option>
                                                                    }
                                                                </select>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label text-dark fw-medium">Trạng thái hoạt động</label>
                                                                <select class="form-select shadow-none" name="trangThai">
                                                                    @if (user.TrangThai == 1)
                                                                    {
                                                                        <option value="1" selected>Hoạt động bình thường
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="1">Hoạt động bình thường</option>
                                                                    }
                                                                    @if (user.TrangThai == 0)
                                                                    {
                                                                        <option value="0" selected>Chờ duyệt</option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="0">Chờ duyệt</option>
                                                                    }
                                                                    @if (user.TrangThai == 2)
                                                                    {
                                                                        <option value="2" selected>Khóa tài khoản
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {

                                                                        <option value="2">Khóa tài khoản</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer border-top">
                                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                                                            <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }

                                <div class="modal fade" id="addUserModal" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content custom-card p-0">
                                            <div class="modal-header border-bottom">
                                                <h5 class="modal-title fw-bold text-dark">Thêm tài khoản nhân sự mới</h5>
                                                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="AddUser" method="post">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label class="form-label text-dark fw-medium">Tên đăng nhập <span
                                                            class="text-danger">*</span></label>
                                                            <input type="text" class="form-control shadow-none" name="TenDangNhap"
                                                                   placeholder="Ví dụ: bs_lan" required />
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label text-dark fw-medium">Mật khẩu <span
                                                                class="text-danger">*</span></label>
                                                                <input type="password" class="form-control shadow-none" name="MatKhau" required
                                                                       minlength="5" placeholder="Tối thiểu 5 ký tự" />
                                                            </div>
                                                            <div class="mb-3">
                                                                <label class="form-label text-dark fw-medium">Họ và tên hiển thị <span
                                                                    class="text-danger">*</span></label>
                                                                    <input type="text" class="form-control shadow-none" name="HoTen"
                                                                           placeholder="Ví dụ: Nguyễn Thị Lan" required />
                                                                </div>
                                                                <div class="mb-3">
                                                                    <label class="form-label text-dark fw-medium">Phân quyền vai trò</label>
                                                                    <select class="form-select shadow-none" name="VaiTro" required>
                                                                        <option value="DuocSi">Dược Sĩ</option>
                                                                        <option value="BacSi">Bác Sĩ</option>
                                                                        <option value="QuanLy">Quản Lý</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer border-top">
                                                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy bỏ</button>
                                                                <button type="submit" class="btn btn-primary px-4"><i
                                                                    class="bi bi-person-plus me-2"></i>Tạo tài khoản</button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="logs-panel" role="tabpanel">
                                                <h5 class="fw-bold border-bottom pb-3 mb-4 text-dark">Nhật ký hoạt động hệ thống</h5>
                                                <ul class="list-group list-group-flush">
                                                    @if (ViewBag.Logs != null)
                                                    {
                                                        foreach (var log in ViewBag.Logs)
                                                        {
                                                            var badgeColor = log.Loai == "Danger" ? "danger" : (log.Loai == "Warning" ? "warning text-dark" :
                                    "info text-dark");
                                                            <li class="list-group-item px-0 py-3 text-muted bg-transparent"
                                                                style="border-color: var(--bs-border-color);">
                                                                <span class="badge bg-@badgeColor me-2">@log.Loai</span>
                                                                [@log.ThoiGian.ToString("dd/MM/yyyy HH:mm")]
                                                                <b class="text-dark">@log.NguoiThucHien</b>: @log.NoiDung
                                                            </li>
                                                        }
                                                    }
                                                </ul>
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                @section Scripts {
                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {
                                            const toggle = document.getElementById('darkModeToggle');
                                            const htmlTag = document.documentElement;

                                            if (htmlTag.getAttribute('data-bs-theme') === 'dark') {
                                                toggle.checked = true;
                                            }

                                            toggle.addEventListener('change', function () {
                                                if (this.checked) {
                                                    htmlTag.setAttribute('data-bs-theme', 'dark');
                                                    localStorage.setItem('theme', 'dark');
                                                } else {
                                                    htmlTag.setAttribute('data-bs-theme', 'light');
                                                    localStorage.setItem('theme', 'light');
                                                }
                                            });

                                            var activeTabObj = '@TempData["ActiveTab"]';
                                            if (activeTabObj !== '') {
                                                document.querySelector('#system-tabs .nav-link.active').classList.remove('active');
                                                document.querySelector('.tab-content .tab-pane.show.active').classList.remove('show', 'active');

                                                var triggerEl = document.querySelector('button[data-bs-target="#' + activeTabObj + '"]');
                                                var targetPane = document.getElementById(activeTabObj);

                                                if (triggerEl && targetPane) {
                                                    triggerEl.classList.add('active');
                                                    targetPane.classList.add('show', 'active');
                                                }
                                            }
                                        });
                                    </script>
                                }