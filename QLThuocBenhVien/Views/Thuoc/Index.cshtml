@model IEnumerable<QLThuocBenhVien.Models.Thuoc>

@{
    ViewData["Title"] = "Danh Mục Thuốc Theo Nhóm Bệnh";
}

<h2 class="text-primary mt-4">Danh Mục Thuốc Bệnh Viện</h2>

<form asp-action="Index" method="get" class="mb-4 d-flex align-items-center">
    <label class="me-2 fw-bold">Chọn nhóm bệnh điều trị:</label>
    <select name="maNhomBenh" asp-items="ViewBag.NhomBenhList" class="form-select w-25 me-2">
        <option value="">-- Tất cả nhóm bệnh --</option>
    </select>
    <button type="submit" class="btn btn-success">Lọc Thuốc</button>
</form>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Mã Thuốc</th>
            <th>Tên Thuốc</th>
            <th>Hoạt Chất</th>
            <th>Nhóm Bệnh Điều Trị</th>
            <th>Tồn Kho</th>
            <th>Hạn Sử Dụng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaThuoc</td>
                <td class="fw-bold">@item.TenThuoc</td>
                <td>@item.HoatChat</td>
                <td>
                    @foreach (var tnb in item.ThuocNhomBenhs)
                    {
                        <span class="badge bg-info text-dark">@tnb.NhomBenh.TenNhomBenh</span>
                    }
                </td>
                <td>@item.SoLuongTon</td>
                <td>@item.HanSuDung.ToString("dd/MM/yyyy")</td>
            </tr>
        }
    </tbody>
</table>