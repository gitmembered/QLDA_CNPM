@model IEnumerable<QLThuocBenhVien.Models.Thuoc>
@{
    ViewData["Title"] = "Danh Mục Kho Thuốc";
}

<style>
    /* CSS ghi đè riêng cho trang này để bảng đẹp hơn */
    .table th {
        border-bottom: 2px solid #E5E7EB;
        color: #6B7280;
        font-size: 0.85rem;
        padding: 15px;
        background: transparent;
    }

    .table td {
        vertical-align: middle;
        padding: 15px;
        border-bottom: 1px solid #E5E7EB;
        font-weight: 500;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .status-safe {
        background-color: #DEF7EC;
        color: #03543F;
    }

    .status-warning {
        background-color: #FEF3C7;
        color: #92400E;
    }

    .status-critical {
        background-color: #FDE8E8;
        color: #9B1C1C;
    }

    /* Fix nền dropdown khi ở chế độ tối */
    [data-bs-theme="dark"] .status-safe {
        background-color: rgba(3, 84, 63, 0.3);
        color: #31C48D;
    }

    [data-bs-theme="dark"] .status-warning {
        background-color: rgba(146, 64, 14, 0.3);
        color: #FACA15;
    }

    [data-bs-theme="dark"] .status-critical {
        background-color: rgba(155, 28, 28, 0.3);
        color: #F87171;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Danh Mục Kho Thuốc</h3>
        <p class="text-muted mb-0">Quản lý và theo dõi tồn kho của bệnh viện.</p>
    </div>
    <a asp-controller="Thuoc" asp-action="Create" class="btn btn-primary px-4 fw-medium shadow-sm"
       style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-2"></i>Thêm Mới
    </a>
</div>

<div class="custom-card p-0 overflow-hidden">

    <div class="p-4 border-bottom bg-light">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i
                            class="bi bi-search"></i></span>
                            <input type="text" name="searchString" value="@ViewData["CurrentSearch"]"
                                   class="form-control border-start-0 ps-0 shadow-none bg-transparent"
                                   placeholder="Tìm kiếm thuốc theo tên..."
                                   onkeypress="if(event.keyCode==13){ this.form.submit(); }">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="maNhomBenh" class="form-select shadow-none" asp-items="ViewBag.NhomBenhList"
                                onchange="document.getElementById('filterForm').submit();">
                            <option value="">Tất cả nhóm bệnh</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="trangThai" class="form-select shadow-none"
                                onchange="document.getElementById('filterForm').submit();">
                            <option value="">Tất cả trạng thái</option>
                            @if (ViewData["CurrentTrangThai"]?.ToString() == "AnToan")
                            {
                                <option value="AnToan" selected>An
                                    toàn (> 50)</option>
                                } else
                                {

                                    <option value="AnToan">An toàn (> 50)</option>
                                }
                                @if (ViewData["CurrentTrangThai"]?.ToString() == "SapHet")
                                {
                                    <option value="SapHet" selected>Sắp
                                        hết hàng (1 - 50)</option>
                                    } else
                                    {

                                        <option value="SapHet">Sắp hết hàng (1 - 50)</option>
                                    }
                                    @if (ViewData["CurrentTrangThai"]?.ToString() == "HetHang")
                                    {
                                        <option value="HetHang" selected>
                                            Hết hàng (0)</option>
                                        } else
                                        {

                                            <option value="HetHang">Hết hàng (0)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="table-responsive">
                        <table class="table mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Mã</th>
                                    <th>Tên Thuốc</th>
                                    <th>Nhóm Bệnh</th>
                                    <th>Tồn Kho</th>
                                    <th>Trạng Thái</th>
                                    <th class="text-end pe-4">Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary ps-4">MED-@item.MaThuoc.ToString("D3")</td>
                                            <td class="fw-bold text-dark">@item.TenThuoc</td>
                                            <td>
                                                @if (item.ThuocNhomBenhs != null && item.ThuocNhomBenhs.Any())
                                                {
                                                    <span
                                                    class="badge bg-secondary-subtle text-secondary">@item.ThuocNhomBenhs.First().NhomBenh.TenNhomBenh</span>
                                                }
                                            </td>
                                            <td class="fw-bold">@item.SoLuongTon</td>

                                            <td>
                                                @if (item.SoLuongTon == 0)
                                                {
                                                    <span class="status-badge status-critical"><i class="bi bi-x-octagon me-1"></i>Hết hàng</span>
                                                }
                                                else if (item.HanSuDung != DateTime.MinValue && item.HanSuDung <= DateTime.Now.AddDays(30))
                                                {
                                                    <span class="status-badge status-warning"><i class="bi bi-clock-history me-1"></i>Sắp hết
                                                        hạn</span>
                                                    }
                                                else if (item.SoLuongTon <= 50)
                                                    {
                                                        <span class="status-badge status-warning"><i class="bi bi-exclamation-triangle me-1"></i>Sắp hết
                                                            hàng</span>
                                                        }
                                                else
                                                        {
                                                            <span class="status-badge status-safe"><i class="bi bi-check-circle me-1"></i>An toàn</span>
                                                        }
                                                    </td>

                                                    <td class="text-end pe-4">
                                                        <a asp-action="Edit" asp-route-id="@item.MaThuoc" class="btn btn-sm btn-light text-primary me-2"
                                                           title="Chỉnh sửa">
                                                            <i class="bi bi-pencil"></i>
                                                        </a>
                                                        <a asp-action="Delete" asp-route-id="@item.MaThuoc" class="btn btn-sm btn-light text-danger"
                                                           title="Xóa"
                                                           onclick="return confirm('Bạn có chắc chắn muốn xóa thuốc @item.TenThuoc khỏi hệ thống?');">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center py-5 text-muted">
                                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                                                    Không tìm thấy loại thuốc nào phù hợp với điều kiện lọc.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div> ```

