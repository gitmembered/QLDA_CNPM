@model QLThuocBenhVien.Models.Thuoc
@{
    ViewData["Title"] = "Khai Báo Danh Mục Dược Phẩm";
}

<div class="mb-4">
    <h3 class="fw-bold mb-1">Khai Báo Dược Phẩm Mới</h3>
    <p class="text-muted mb-0">Thêm tên thuốc được phép sử dụng trong bệnh viện vào danh mục hệ thống.</p>
</div>

<div class="custom-card p-4">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold text-dark">Tên thương mại của thuốc <span
                    class="text-danger">*</span></label>
                    <input asp-for="TenThuoc" class="form-control shadow-none" placeholder="Ví dụ: Augmentin 1g" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark">Tên các hoạt chất chính <span
                        class="text-danger">*</span></label>
                        <input asp-for="HoatChat" class="form-control shadow-none"
                               placeholder="Ví dụ: Amoxicillin + Acid Clavulanic" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Đơn vị tính gốc <span class="text-danger">*</span></label>
                        <select asp-for="MaDVT" class="form-select shadow-none" asp-items="ViewBag.DonViTinhList" required>
                            <option value="">-- Chọn đơn vị tính --</option>
                        </select>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-bold text-dark">Nhóm bệnh khuyên dùng / Điều trị <span
                            class="text-danger">*</span></label>
                            <select name="MaNhomBenh" class="form-select shadow-none" asp-items="ViewBag.NhomBenhList" required>
                                <option value="">-- Chọn nhóm bệnh điều trị chính --</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-dark">Công Dụng / Chỉ Định Điều Trị</label>
                            <textarea asp-for="CongDung" class="form-control shadow-none" rows="3"
                                      placeholder="Ghi rõ chỉ định lâm sàng, chống chỉ định cơ bản của thuốc..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light px-4">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-4 fw-medium">Khai báo danh mục</button>
                    </div>
                </form>
            </div>