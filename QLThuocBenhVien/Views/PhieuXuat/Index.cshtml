@model IEnumerable<QLThuocBenhVien.Models.PhieuXuat>
@{
    ViewData["Title"] = "Lịch Sử Xuất Kho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Lịch Sử Xuất Kho</h3>
        <p class="text-muted mb-0">Xem lại và giám sát toàn bộ danh sách chứng từ cấp phát thuốc cho các khoa.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 fw-medium shadow-sm" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-2"></i>Lập Phiếu Mới
    </a>
</div>

<div class="custom-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">MÃ PHIẾU</th>
                    <th>NGÀY XUẤT KHO</th>
                    <th>KHOA LÂM SÀNG NHẬN</th>
                    <th>TỔNG GIÁ TRỊ</th>
                    <th class="text-end pe-4">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary ps-4">#PX-@item.MaPhieuXuat.ToString("D4")</td>
                            <td>@item.NgayXuat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-info-subtle text-info px-2 py-1.5 fs-7">Khoa Số @item.MaKhoa</span></td>
                            <td class="fw-bold text-danger">@item.TongTien.ToString("N0") VNĐ</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.MaPhieuXuat"
                                   class="btn btn-sm btn-light text-primary fw-medium">
                                    <i class="bi bi-eye me-1"></i> Xem chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                            Chưa có dữ liệu phiếu xuất kho nào được lập.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>